# MongoDB Atlas Connection String
# Replace <username>, <password>, and <cluster-url> with your exact Atlas cluster details
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>.mongodb.net/newsports?retryWrites=true&w=majority&appName=Cluster0

# JSON Web Token Secret
# Change this to a strong, random alphanumeric string for production
JWT_SECRET=supersecretjwtkey_12345_newsports
